DEF LINE_TRACKER Robot {
  translation 0 -5 1
  rotation 0 0 1 1.570796
  controller "line_tracker"
  supervisor TRUE

  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.15 0.15 0.18
        roughness 1
        metalness 0
      }
      geometry Box {
        size 0.36 0.36 0.1
      }
    }

    Transform {
      translation 0.16 0 0.07
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.9 0.2 0.2
            roughness 1
            metalness 0
          }
