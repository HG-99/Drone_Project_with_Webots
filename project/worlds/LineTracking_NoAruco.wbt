            size 0.1 0.04 0.03
          }
        }
      ]
    }

    DEF FRONT_CAMERA Camera {
      translation 0.2 0 0.02
      rotation 0 0 1 0
      name "front_camera"
      width 640
      height 480
      fieldOfView 1.2
      near 0.02
    }

    DEF DOWN_CAMERA Camera {
      translation 0 0 -0.14
      rotation 0 1 0 1.5708
      name "down_camera"
      width 640
      height 480
      fieldOfView 1.2
      near 0.02
    }
  ]

  name "line_tracker"
  boundingObject Box {
    size 0.36 0.36 0.1
  }
}
